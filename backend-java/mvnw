# Java version
if [ -z "$JAVA_HOME" ] ; then
  JAVA_CMD=java
else
  JAVA_CMD="$JAVA_HOME/bin/java"
fi

# Check Java version
MAVEN_WRAPPER_VERSION="3.1.0"
MAVEN_WRAPPER_DIST_URL="${MAVEN_WRAPPER_DOWNLOAD_URL:-https://repo.maven.apache.org/maven2/io/takari/maven-wrapper/0.7.7/maven-wrapper-0.7.7.jar}"

if [ ! -d "$HOME/.m2/wrapper" ]; then
  mkdir -p "$HOME/.m2/wrapper"
fi

WRAPPER_JAR="$HOME/.m2/wrapper/maven-wrapper.jar"

if [ ! -f "$WRAPPER_JAR" ]; then
  echo "Downloading maven-wrapper..."
  curl -sS "$MAVEN_WRAPPER_DIST_URL" -o "$WRAPPER_JAR"
fi

exec "$JAVA_CMD" -cp "$WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"

